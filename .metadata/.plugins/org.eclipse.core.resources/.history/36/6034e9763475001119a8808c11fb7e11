package com.java.basic;

public class OperatorsPractice {

	public static void main(String[] args) {

		/** Operators Types
		 *  Arithmetic Operators ( +, -, *, /, % )
		 *  Relational Operators ( ==, !=, >, <, >=, <= )
		 *  Assignment Operators ( =, +=, -=, *=, /=, %= )
		 *  Bitwise Operators    ( &, |, ^, ~ )
		 *  Logical Operators    ( &&, ||, ! )
		 *  Ternary Operators    ( ? : )
		 *  Unary Operators      ( ++, -- ) 
		 *  Shift Operators      ( <<, >>, >>> )
		 */
		
		// =================================
		// 1) ARITHMETIC OPERATORS
		// =================================
		int a = 10; 
		int b = 5;
		System.out.println("1) ARITHMETIC OPERATORS ");
		System.out.println("===========================");
		System.out.println();
		System.out.println("  Addition       (+) :    " + a + " + " + b + " = " + ( a + b ));
		System.out.println("  Subtraction    (-) :    " + a + " - " + b + " = " + ( a - b ));
		System.out.println("  Multiplication (*) :    " + a + " * " + b + " = " + ( a * b ));
		System.out.println("  Division       (/) :    " + a + " / " + b + " = " + ( a / b ));
		System.out.println("  Modulus        (%) :    " + a + " % " + b + " = " + ( a % b ));
		
		// =================================
		// 2) RELATIONAL OPERATORS
		// =================================
		int ra = 10; 
		int rb = 5;
		System.out.println();
		System.out.println("2) RELATIONAL OPERATORS ");
		System.out.println("===========================");
		System.out.println();
		System.out.println("  Equal                  (==) :    " + ra + " == " + rb + " = " + ( ra == rb ));
		System.out.println("  Not Equal              (!=) :    " + ra + " != " + rb + " = " + ( ra != rb ));
		System.out.println("  Greater Than           (>)  :    " + ra + " >  " + rb + " = " + ( ra >  rb ));
		System.out.println("  Greater Than Equal To  (>=) :    " + ra + " >= " + rb + " = " + ( ra >= rb ));
		System.out.println("  Less Than              (<)  :    " + ra + " <  " + rb + " = " + ( ra <  rb ));
		System.out.println("  Less Than Equal To     (<=) :    " + ra + " <= " + rb + " = " + ( ra <= rb ));
		
		// =================================
		// 3) ASSIGNMENT OPERATORS
		// =================================
		int av = 10; 
		System.out.println();
		System.out.println("3) ASSIGNMENT OPERATORS ");
		System.out.println("===========================");
		System.out.println();
		System.out.println("  Equal Assignment          (=)  :   " +"av = " + av );
		System.out.println("  Addition Assignment       (+=) :   " +"av += 5" + " => " + ( av += 5 ) );
		System.out.println("  Subtraction Assignment    (-=) :   " +"av -= 5" + " => " + ( av -= 5 ) );
		System.out.println("  Multiplication Assignment (*=) :   " +"av *= 5" + " => " + ( av *= 5 ) );
		System.out.println("  Division Assignment       (/=) :   " +"av /= 5" + " => " + ( av /= 5 ) );
		System.out.println("  Modulus Assignment        (%=) :   " +"av %= 4" + " => " + ( av %= 4 ) );
		
		// =================================
		// 4) BITWISE OPERATORS
		// =================================
		int ba = 10; 
		int bb = 5;
		System.out.println();
		System.out.println("4) BITWISE OPERATORS ");
		System.out.println("===========================");
		System.out.println(" Bitwise AND          (&) :    " + ba + " & " + bb + " = " + ( ba & bb ));
		System.out.println(" Bitwise OR           (|) :    " + ba + " | " + bb + " = " + ( ba | bb ));
		System.out.println(" Bitwise XOR          (^) :    " + ba + " ^ " + bb + " = " + ( ba ^ bb ));
		System.out.println(" Bitwise Complement   (~) :    " + "~" + ba + " = " + ( ~ba ));

		// =================================
		// 5) LOGICAL OPERATORS
		// =================================
		int la = 9; 
		int lb = 5;
		int lc = 6;
		int ld = 2;
		System.out.println();
		System.out.println("5) LOGICAL OPERATORS ");
		System.out.println("===========================");
		System.out.println(" Both condition should be true         (&&) :  " + (la>lb) + " && " + (lc>ld) + " = " + ( ( la > lb ) && ( lc > ld ) ));
		System.out.println(" Both condition should be true         (&&) :  " + (la<lb) + " && " + (lc>ld) + " = " + ( ( la < lb ) && ( lc > ld ) ));
		System.out.println(" Either one condition should be true   (||) :  " + (la<lb) + " || " + (lc>ld) + " = " + ( ( la < lb ) || ( lc > ld ) ));
		System.out.println(" Either one condition should be true   (||) :  " + (la>lb) + " || " + (lc>ld) + " = " + ( ( la > lb ) || ( lc > ld ) ));
				
		// =================================
		// 6) TERNARY OPERATORS
		// =================================
		int ta = 1; 
		int tb = 5;
		System.out.println();
		System.out.println("6) TERNARY OPERATORS ");
		System.out.println("===========================");
		System.out.println(" It works based on true or false condition");
		System.out.print(" condition ? true : false => " + ta + ">" + tb );
		String answer = ta > tb ? "true" : "false";
		System.out.println(" " + answer);
				
				
		// =================================
		// 7) SHIFT OPERATORS
		// =================================
		int pn = 10; 
		int nn = -10;
		System.out.println();
		System.out.println("7) SHIFT OPERATORS ");
		System.out.println("===========================");
		System.out.println(" Signed Left Shift      (<<)  :     " + pn + " <<  2" + " =  " + ( pn << 2 ));
		System.out.println(" Signed Left Shift      (<<)  :    " + nn + " <<  2" + " = " + ( nn << 2 ));
		System.out.println(" Signed Right Shift     (>>)  :     " + pn + " >>  2" + " =  " + ( pn >> 2 ));
		System.out.println(" Signed Right Shift     (>>)  :    " + nn + " >>  2" + " = " + ( nn >> 2 ));
		System.out.println(" Unsigned Right Shift   (>>>) :     " + pn + " >>> 2" + " =  " + ( pn >>> 2 ));
		System.out.println(" Unsigned Right Shift   (>>>) :    " + nn + " >>> 2" + " = " + ( nn >>> 2 ));		
				
				
	}

}
