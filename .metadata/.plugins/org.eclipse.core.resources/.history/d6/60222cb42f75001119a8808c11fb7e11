package com.java.basic;

public class OperatorsPractice {

	public static void main(String[] args) {

		/** Operators Types
		 *  Arithmetic Operators ( +, -, *, /, % )
		 *  Relational Operators ( ==, !=, >, <, >=, <= )
		 *  Assignment Operators ( =, +=, -=, *=, /=, %= )
		 *  Bitwise Operators    ( &, |, ^, ~ )
		 *  Logical Operators    ( &&, ||, ! )
		 *  Ternary Operators    ( ? : )
		 *  Unary Operators      ( ++, -- ) 
		 *  Shift Operators      ( <<, >>, >>> )
		 */
		
		// =================================
		// 1) ARITHMETIC OPERATORS
		// =================================
		int a = 10; 
		int b = 5;
		System.out.println("1) ARITHMETIC OPERATORS ");
		System.out.println("===========================");
		System.out.println(" Addition       (+) :    " + a + " + " + b + " = " + ( a + b ));
		System.out.println(" Subtraction    (-) :    " + a + " - " + b + " = " + ( a - b ));
		System.out.println(" Multiplication (*) :    " + a + " * " + b + " = " + ( a * b ));
		System.out.println(" Division       (/) :    " + a + " / " + b + " = " + ( a / b ));
		System.out.println(" Modulus        (%) :    " + a + " % " + b + " = " + ( a % b ));
		
		// =================================
		// 2) RELATIONAL OPERATORS
		// =================================
		int ra = 10; 
		int rb = 5;
		System.out.println();
		System.out.println("2) RELATIONAL OPERATORS ");
		System.out.println("===========================");
		System.out.println(" Equal                  (==) :    " + ra + " == " + rb + " = " + ( ra == rb ));
		System.out.println(" Not Equal              (!=) :    " + ra + " != " + rb + " = " + ( ra != rb ));
		System.out.println(" Greater Than           (>)  :    " + ra + " >  " + rb + " = " + ( ra >  rb ));
		System.out.println(" Greater Than Equal To  (>=) :    " + ra + " >= " + rb + " = " + ( ra >= rb ));
		System.out.println(" Less Than              (<)  :    " + ra + " <  " + rb + " = " + ( ra <  rb ));
		System.out.println(" Less Than Equal To     (<=) :    " + ra + " <= " + rb + " = " + ( ra <= rb ));
		
		// =================================
		// 3) ASSIGNMENT OPERATORS
		// =================================
		int av = 10; 
		System.out.println();
		System.out.println("3) ASSIGNMENT OPERATORS ");
		System.out.println("===========================");
		System.out.println(" Equal Assignment          (=)  :   " +"av = " + av );
		System.out.println(" Addition Assignment       (+=) :   " +"av += 5" + " => " + ( av += 5 ) );
		System.out.println(" Subtraction Assignment    (-=) :   " +"av -= 5" + " => " + ( av -= 5 ) );
		System.out.println(" Multiplication Assignment (*=) :   " +"av *= 5" + " => " + ( av *= 5 ) );
		System.out.println(" Division Assignment       (/=) :   " +"av /= 5" + " => " + ( av /= 5 ) );
		System.out.println(" Modulus Assignment        (%=) :   " +"av %= 4" + " => " + ( av %= 4 ) );
		
		
	}

}
